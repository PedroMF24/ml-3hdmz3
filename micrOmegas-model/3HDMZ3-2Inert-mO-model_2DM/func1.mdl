Z33HDM
 Constraints
 Name     |> Expression                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       <|
CW       |sqrt(1-pow(SW,2))               % CW
GF       |EE^2/(2*SW*MW)^2/Sqrt2 %  experimental value 1.166E-5 [1/GeV^2]
MZ       |MW/CW % Z boson mass
LamQCD   |initQCD5(alphaSMZ, McMc, MbMb, Mtp)
Mb       |MbEff(Q)
Mc       |McEff(Q)
Ms       |MqEff(0.096, Q) % s-quark effective mass  via 2MeV running one
vv       |2*MW/EE*SW                      % vv
L3       |pow(mh/vv,2)/2.                                                                           % L3
L8       |( - 2*pow(mH1P,2) + pow(mH1,2) + pow(mH2,2) + (pow(mH1,2) - pow(mH2,2))*cos(2*theta))/pow(vv,2)   % L8
L5       |(2*pow(mH1P,2) - 2*pow(mH1,2))/pow(vv,2) - g1 + g2*sin(theta)/cos(theta)                   % L5 
L12      |(pow(mH1,2)-pow(mH2,2)*sin(2*theta))/pow(vv,2)                                 % L12
L9       |(- 2*pow(mH2P,2) + pow(mH1,2) + pow(mH2,2) + (-pow(mH1,2) + pow(mH2,2))*cos(2*theta))/pow(vv,2)   % L9
L6       |(2*pow(mH2P,2) - 2*pow(mH1,2))/pow(vv,2) - g1 - g2*cos(theta)/sin(theta)                    % L6
LGGH     |-cabs(lGGhiggs(mh,"h"))
LAAH     |-cabs(lAAhiggs(mh,"h"))
aQCD_h   |alphaQCD(mh)/PI
Rqcd_h   |sqrt(1+aQCD_h*(149/12+aQCD_h*(68.6482-aQCD_h*212.447)))
xiW            |1.
xiZ            |1.
xiA            |1.
xiG            |1.
CKM1x1         |1.                                                                                                              % CKM1x1                                            
CKM1x2         |0.                                                                                                              % CKM1x2                                            
CKM1x3         |0.                                                                                                              % CKM1x3                                            
